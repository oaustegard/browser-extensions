{
  "manifest_version": 3,
  "name": "Open Link in Profile",
  "version": "1.1.0",
  "description": "Right-click a link and open it in a different Chrome profile.",
  "permissions": ["contextMenus", "nativeMessaging"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
