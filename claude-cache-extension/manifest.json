{
  "manifest_version": 3,
  "name": "Claude Conversation Cache",
  "version": "0.4.5",
  "description": "Continuously caches Claude.ai conversations to prevent data loss on UX crashes",
  
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  
  "host_permissions": [
    "https://claude.ai/*"
  ],
  
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-script-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-script-isolated.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Cache"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
