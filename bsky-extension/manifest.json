{
  "manifest_version": 3,
  "name": "Bluesky Enhancements",
  "version": "1.2",
  "description": "A collection of quality-of-life improvements and tools for Bluesky via context menus, powered by oaustegard.github.io/bsky utilities.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://bsky.app/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://bsky.app/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}